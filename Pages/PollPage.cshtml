@page "{id:int}"
@model PollStation.Pages.PollPageModel

<!--Hier nog de indeling goed zetten en de progressbar customizen!! daarbij pijltjes naar volgende qeustion-->
<div class="questionArea">

    <div class="customPollPage">
    <div class="onlineCounter">
        Users connected: <span id="onlineUsers">0</span>
    </div>

    <h1>@Model.Poll.Question</h1>

    <!-- QR CODE -->
    @if (Model.Poll.QrCode != null)
    {
        <div class="qrArea">
            <p>Scan to vote</p>
            <img src="data:image/png;base64,@Model.Poll.QrCode" width="160" />
        </div>
    }

    <div class="pollButtonArea">

        @foreach (var option in Model.Poll.Options)
        {
            <form method="post" asp-page-handler="Vote">

                <input type="hidden" name="optionId" value="@option.UserId" />
                <input type="hidden" name="pollId" value="@Model.Poll.UserId" />

                <button class="btn btn-primary pollButton">
                    @option.Text
                </button>

            </form>
        }

    </div>

    <hr />

    <h3>Results</h3>

    <!-- STACKED PROGRESS BAR -->
    <div class="progress bigProgress">

        @{
            var colors = new string[]
            {
                "bg-success",
                "bg-info",
                "bg-warning",
                "bg-danger"
            };

            int i = 0;
        }

        @foreach (var option in Model.Poll.Options)
        {
            var percent = Model.Percentage(option.Votes);
            var color = colors[i % colors.Length];

            <div class="progress-bar @color"
                 role="progressbar"
                 style="width:@percent%">

                @option.Text (@percent%)

            </div>

            i++;
        }

    </div>

    <!-- LEGEND -->
    <div class="legend">

        @foreach (var option in Model.Poll.Options)
        {
            var percent = Model.Percentage(option.Votes);

            <div>
                <strong>@option.Text</strong> — @percent% (@option.Votes votes)
            </div>
        }
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/pollhub")
            .build();

        connection.on("PollUpdated", function () {

            location.reload();

        });

        connection.on("UpdateUsers", function (count) {
            document.getElementById("onlineUsers").innerText = count;
        });
        connection.start();
    </script>
    </div>
</div>



<style>

    .questionArea {
        display: flex;
        flex-direction: column;
        text-align: center;
        border: solid 2px black;
        background-image: url('/Images/BackgroundGreen.png');
        background-size: cover;
        background-repeat: no-repeat;
        margin-top: 30px;
    }

    .customPollPage {
        margin: 2rem;
        background-color: #fafafa;
        border: solid 2px black;
        border-radius: 5px;
    }

    .qrArea {
        margin: 20px;
    }

    .pollButtonArea {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .pollButton {
        width: 250px;
        margin: 10px;
    }

    .bigProgress {
        height: 40px;
        margin-top: 20px;
    }

    .legend {
        margin-top: 15px;
    }

</style>