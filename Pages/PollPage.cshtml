@page "{id:int}"
@using PollStation.Models
@model PollStation.Pages.PollPageModel
@Html.AntiForgeryToken()

<div class="questionArea">
    <div class="customPollPage">
        <div class="onlineCounter">
            Users connected: <span id="onlineUsers">0</span>
        </div>

        <!-- QR CODE -->
        @if (!string.IsNullOrEmpty(Model.Poll?.QrCode))
        {
            <a href="@Url.Page("/PollPage", new { id = Model.Poll.Id })">
                <img src="data:image/png;base64,@Model.Poll.QrCode" width="160" />
            </a>
        }

        <!-- POLL BUTTONS -->
        <div class="pollButtonArea">
            @foreach (var option in Model.Poll?.Options ?? Enumerable.Empty<PollOption>())
            {
                <button class="btn btn-primary pollButton optionBtn"
                        data-option-id="@option.Id"
                        onclick="vote(@option.Id, @Model.Poll?.Id ?? 0)">
                    @option.Text
                </button>
            }
        </div>

        <hr />

        <h3>Results</h3>

        <!-- STACKED PROGRESS BAR -->
        <div class="progress bigProgress">
            @{
                var colors = new string[] { "bg-success", "bg-info", "bg-warning", "bg-danger" };
                int i = 0;
            }

            @foreach (var option in Model.Poll?.Options ?? Enumerable.Empty<PollOption>())
            {
                var percent = Model.Percentage(option.Votes);
                var color = colors[i % colors.Length];

                <div class="progress-bar @color"
                     role="progressbar"
                     data-option-id="@option.Id"
                     data-votes="@option.Votes"
                     style="width:@percent%">
                    @option.Text (@percent%)
                </div>

                i++;
            }
        </div>

        <!-- LEGEND -->
        <div class="legend">
            @foreach (var option in Model.Poll?.Options ?? Enumerable.Empty<PollOption>())
            {
                var percent = Model.Percentage(option.Votes);
                <div>
                    <strong>@option.Text</strong> — @percent% (@option.Votes votes)
                </div>
            }
        </div>
    </div>
</div>

<style>
    .questionArea {
        display: flex;
        flex-direction: column;
        text-align: center;
        border: solid 2px black;
        background-image: url('/Images/BackgroundGreen.png');
        background-size: cover;
        background-repeat: no-repeat;
        margin-top: 30px;
    }

    .customPollPage {
        margin: 2rem;
        background-color: #fafafa;
        border: solid 2px black;
        border-radius: 5px;
    }

    .qrArea {
        margin: 20px;
    }

    .pollButtonArea {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .pollButton {
        width: 250px;
        margin: 10px;
    }

    .bigProgress {
        height: 40px;
        margin-top: 20px;
    }

    .legend {
        margin-top: 15px;
    }

    .optionBtn.selected {
        background-color: #28a745 !important;
        border: 2px solid black;
        transform: scale(1.05);
    }

    .optionBtn:hover {
        transform: scale(1.03);
        transition: 0.2s;
    }

    .progress-bar {
        transition: width 0.6s ease-in-out;
    }
</style>